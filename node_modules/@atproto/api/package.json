{
  "name": "@atproto/api",
  "version": "0.20.25",
  "license": "MIT",
  "description": "Client library for atproto and Bluesky",
  "keywords": [
    "atproto",
    "bluesky",
    "api"
  ],
  "homepage": "https://atproto.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bluesky-social/atproto",
    "directory": "packages/api"
  },
  "files": [
    "./dist",
    "./OAUTH.md",
    "./README.md",
    "./CHANGELOG.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "await-lock": "^3.0.0",
    "multiformats": "^13.0.0",
    "tlds": "^1.234.0",
    "zod": "^3.23.8",
    "@atproto/common-web": "^0.5.3",
    "@atproto/syntax": "^0.6.4",
    "@atproto/xrpc": "^0.8.3",
    "@atproto/lexicon": "^0.7.4"
  },
  "devDependencies": {
    "@jest/globals": "^28.1.3",
    "http-terminator": "^3.2.0",
    "jest": "^30.0.0",
    "prettier": "^3.2.5",
    "@atproto/lex-cli": "^0.10.3"
  },
  "scripts": {
    "codegen:lex": "lex gen-api --yes ./src/client ../../lexicons/com/atproto/*/* ../../lexicons/app/bsky/*/* ../../lexicons/chat/bsky/*/* ../../lexicons/tools/ozone/*/* ../../lexicons/com/germnetwork/*",
    "codegen:code": "node ./scripts/generate-code.mjs",
    "prebuild": "pnpm run codegen:code && if [ ! -f ./src/client/index.ts ] || [ -n \"$(find ../../lexicons -name '*.json' -newer ./src/client/index.ts -type f -print -quit)\" ]; then pnpm run codegen:lex; fi",
    "build": "tsgo --build tsconfig.build.json",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest"
  }
}